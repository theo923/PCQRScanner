{
  "manifest_version": 3,
  "name": "Quick QR Scanner",
  "version": "1.0.0",
  "description": "Instantly scan QR codes visible on any browser tab — no camera needed. One click to decode URLs, text, and more.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Quick QR Scanner",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}

